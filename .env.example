# Runtime
APP_MODE=tenant
NODE_ENV=development
PORT=3000
APP_VERSION=development
IMAGE_DIGEST=
SERVE_FRONTEND=true

# Database and cache (injected from the tenant/control-plane secret in production)
MONGO_URI=
# Optional non-SRV fallback. Must be a complete mongodb:// URI with TLS and replica-set options.
MONGO_URI_STANDARD=
MONGO_DB_NAME=
MONGO_SERVER_SELECTION_TIMEOUT_MS=15000
NODE_DNS_SERVERS=1.1.1.1,8.8.8.8
REDIS_URL=
# Bull producer commands fail fast after this many Redis retries; workers keep retrying safely.
BULL_REDIS_MAX_RETRIES_PER_REQUEST=3
JWT_SECRET=
JWT_EXPIRES_IN=7h

# Tenant runtime
TENANT_ID=demo
TENANT_SLUG=demo
TENANT_COMPANY_NAME=Demo Airlines
TENANT_DOMAIN=demo.airlineplan.com
TENANT_FEATURES_JSON='{"network":true,"sectors":true,"stations":true,"rotations":true,"flgts":true,"dashboard":true,"connections":true,"assignment":true,"fleet":true,"maintenance":true,"poo":true,"revenue":true,"cost":true,"crew":true,"routeEconomics":true,"users":true}'
TENANT_BRANDING_JSON='{"companyName":"Demo Airlines","logoUrl":"","primaryColor":"#0B3B75"}'

# Control-plane administrator
ADMIN_EMAIL=admin@airlineplan.com
ADMIN_PASSWORD_HASH=
ADMIN_JWT_SECRET=
ADMIN_JWT_EXPIRES_IN=8h
PROVISIONING_CALLBACK_SECRET=

# Platform orchestration
AWS_REGION=ap-south-1
TENANT_PROVISIONING_STATE_MACHINE_ARN=
TENANT_EXPORT_STATE_MACHINE_ARN=
TENANT_ECS_CLUSTER_ARN=
TENANT_IMAGE_REPOSITORY=airlineplan-tenant
DEFAULT_APP_VERSION=standard-2026.06.19
BOOTSTRAP_SECRET_KMS_KEY_ARN=
BOOTSTRAP_SECRET_TTL_HOURS=24
ALB_RULE_PRIORITY_START=100
ROOT_DOMAIN=airlineplan.com

# Application services
RESEND_API_KEY=
RESEND_FROM_EMAIL="Airlineplan <admin@mail.airlineplan.com>"
CONTACT_EMAIL=admin@airlineplan.com
SCHEDULE_UPLOAD_LIMIT=
FLIGHT_LIMIT=
